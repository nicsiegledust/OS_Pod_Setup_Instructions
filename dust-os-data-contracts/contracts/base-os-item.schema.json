{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://your-workspace.example.com/contracts/os/base-os-item-v1.schema.json",
  "title": "Command Center OS Base Item v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "type", "text", "state", "source", "evidence", "firstSeen", "lastTouched"],
  "properties": {
    "id": { "type": "string", "minLength": 3 },
    "type": { "enum": ["goal", "commitment", "ask", "decision", "risk", "signal", "follow_up", "account_signal", "decision_needed", "goal_candidate"] },
    "text": { "type": "string", "minLength": 1, "maxLength": 280 },
    "dri": { "oneOf": [{ "type": "string" }, { "type": "null" }, { "type": "object" }] },
    "owner": { "oneOf": [{ "type": "string" }, { "type": "null" }, { "type": "object" }] },
    "due": { "oneOf": [{ "type": "string", "format": "date" }, { "type": "null" }] },
    "state": { "enum": ["proposed", "accepted", "open", "in_progress", "waiting", "blocked", "at_risk", "due_today", "due_today_unconfirmed", "due_next", "overdue", "redated", "done", "rejected", "stale", "closed", "decided", "watch", "green", "amber", "red"] },
    "rag": { "enum": ["green", "yellow", "red", "unknown"] },
    "cpTag": { "oneOf": [{ "type": "string", "pattern": "^(CP[1-7]|\\[drift\\?\\])$" }, { "type": "null" }] },
    "cpTags": { "type": "array", "items": { "type": "string", "pattern": "^(CP[1-7]|\\[drift\\?\\])$" } },
    "ownershipRoute": { "enum": ["Business", "Craft", "Coaching", "Company Decision"] },
    "businessArea": { "oneOf": [{ "enum": ["Product", "Marketing", "Sales", "Customer Experience", "Ecosystem", "Region-US"] }, { "type": "null" }] },
    "craftArea": { "oneOf": [{ "enum": ["Engineering", "Design", "Sales, including BDR", "RevOps", "Solution Engineering", "Customer Success + Deployment + Support", "Marketing", "Field Marketing & Community", "Partnerships", "Talent", "Finance", "Founder Office", "People / Legal"] }, { "type": "null" }] },
    "alignment": { "$ref": "alignment.schema.json" },
    "statusV2": { "$ref": "status.schema.json" },
    "metrics": { "type": "array", "items": { "$ref": "metric.schema.json" } },
    "handoff": { "$ref": "handoff.schema.json" },
    "source": { "type": "object" },
    "evidence": { "oneOf": [{ "type": "array", "items": { "$ref": "evidence.schema.json" } }, { "type": "string" }] },
    "firstSeen": { "type": "string" },
    "lastTouched": { "type": "string" },
    "last_touched": { "type": "string" },
    "visibility": { "enum": ["personal_private", "team_visible", "company_visible", "public_team_visible"] },
    "promotion": { "type": "object" }
  }
}
