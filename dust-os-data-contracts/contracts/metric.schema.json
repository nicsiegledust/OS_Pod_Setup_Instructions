{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://your-workspace.example.com/contracts/os/metric-v1.schema.json",
  "title": "OS Metric v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "unit", "asOf"],
  "properties": {
    "name": { "type": "string" },
    "unit": { "type": "string" },
    "current": { "type": ["number", "integer", "null"] },
    "target": { "type": ["number", "integer", "null"] },
    "baseline": { "type": ["number", "integer", "null"] },
    "percentToGoal": { "type": ["number", "null"] },
    "direction": { "enum": ["higher_is_better", "lower_is_better", "target_band", "informational"] },
    "asOf": { "type": "string" },
    "evidence": { "type": "array", "items": { "$ref": "evidence.schema.json" } },
    "stale": { "type": "boolean" }
  }
}
